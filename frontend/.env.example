# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Server-side API URL (optional; defaults to NEXT_PUBLIC_API_URL)
API_INTERNAL_URL=http://localhost:4000/api

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# First super admin — seeded into MongoDB via: npm run db:seed (from repo root)
ADMIN_EMAIL=admin@afaritrails.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Super Admin
ADMIN_ROLE=super_admin

# Store checkout uses Stripe via the backend API — configure STRIPE_SECRET_KEY in backend/.env

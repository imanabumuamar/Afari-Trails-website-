# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Database (SQLite for local dev — file created in prisma/)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-run-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# First admin (used by npm run db:seed)
ADMIN_EMAIL=admin@afaritrails.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Legacy admin API header (optional fallback)
ADMIN_SECRET=change-me-to-a-long-random-string

NODE_ENV=development
PORT=4000

# Frontend origin (CORS)
CORS_ORIGIN=http://localhost:3000

# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/afari-trails

# Auth — use the same values as frontend/.env.local for seeding
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=3h
ADMIN_EMAIL=admin@afaritrails.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Super Admin
ADMIN_ROLE=super_admin

# Optional — notify on new inquiries (not wired yet; submissions are stored in MongoDB)
# INQUIRY_NOTIFY_EMAIL=hello@afaritrails.com

# Store checkout (Zambia-friendly default: manual order requests, no card processor)
# auto = manual unless STRIPE_SECRET_KEY is set | manual | stripe
CHECKOUT_MODE=manual
STOREFRONT_URL=http://localhost:3000

# Optional Stripe (only if you have a supported-country Stripe account)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

{
  "name": "afari-trails",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "db:up": "node scripts/ensure-mongo.js",
    "db:seed": "npm run seed --prefix backend",
    "dev": "bash scripts/dev.sh",
    "dev:run": "concurrently -n api,web -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv": "^16.5.0",
    "mongoose": "^8.15.1"
  }
}

{
  "name": "afari-trails",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "db:up": "node scripts/ensure-mongo.js",
    "db:seed": "npm run seed --prefix backend",
    "db:sync": "npm run sync --prefix backend",
    "fix:images": "node scripts/fix-broken-images.js",
    "repair": "npm run db:up && npm run fix:images && npm run db:seed && npm run db:sync",
    "doctor": "node scripts/verify-stack.js",
    "dev:check": "node scripts/verify-stack.js",
    "stop": "bash scripts/stop-dev.sh",
    "dev": "bash scripts/dev.sh",
    "dev:site": "bash scripts/stop-dev.sh && npm run dev --prefix frontend",
    "dev:run": "concurrently -k -n api,web -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv": "^16.5.0",
    "mongoose": "^8.15.1"
  }
}
